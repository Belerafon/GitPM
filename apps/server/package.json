{
  "name": "@gitpm/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@gitpm/changes": "workspace:*",
    "@gitpm/drafts": "workspace:*",
    "@gitpm/domain": "workspace:*",
    "@gitpm/git-client": "workspace:*",
    "@gitpm/gitlab": "workspace:*",
    "@gitpm/history": "workspace:*",
    "@gitpm/logging": "workspace:*",
    "@gitpm/shared": "workspace:*",
    "@gitpm/repository-format": "workspace:*",
    "@gitpm/security": "workspace:*",
    "@gitpm/publishing": "workspace:*",
    "@gitpm/validation": "workspace:*",
    "fastify": "5.10.0",
    "pino": "10.3.1"
  },
  "devDependencies": {
    "tsx": "4.23.0"
  }
}
