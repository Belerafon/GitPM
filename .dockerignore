# NOTE: .git is intentionally NOT ignored. The Dockerfile captures the build
# version from it at image build time (see scripts/generate-build-version.mjs)
# and removes it immediately afterwards, so .git never reaches the final image.
.github
.gitpm
.gitpm-local
.tmp
.env
.env.*
coverage
evidence
e2e
fixtures
playwright-report
test-results
docs
node_modules
**/node_modules
**/dist
*.log
*.tsbuildinfo
